// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "sqlite"
}

// Enums
enum EmailType {
  inbound
  outbound
}

enum EventType {
  // outbound
  sent
  delivered
  failed
  scheduled
  // inbound
  received
}

enum RecipientRole {
  to
  cc
  bcc
}

enum DeliveryStatus {
  queued
  success
  failed
}

// Models
model Email {
  id         String    @id @default(uuid())
  type       EmailType
  from       String
  subject    String
  rawBody    String?
  rawHeaders Json?     @default("[]")

  messageId String?
  replyTo   Json?     @default("[]")
  lastEvent EventType

  scheduledAt DateTime?
  createdAt   DateTime  @default(now())

  recipients Recipient[]

  @@index([createdAt])
  @@map("emails")
}

model Recipient {
  id      String @id @default(uuid())
  emailId String

  emailAddress String
  role         RecipientRole

  status EventType
  sentAt DateTime? @default(now())

  error String?
  email Email   @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([emailAddress])
  @@map("recipients")
}

model Webhook {
  id  String @id @default(uuid())
  url String

  events Json @default("[]")

  isActive Boolean @default(true)
  secret   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id        String @id @default(uuid())
  webhookId String

  eventType String
  payload   Json

  status       DeliveryStatus
  httpStatus   Int?
  responseBody String?

  attempts    Int      @default(0)
  attemptedAt DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([eventType])
  @@index([status])
  @@index([attemptedAt])
  @@map("webhook_deliveries")
}
